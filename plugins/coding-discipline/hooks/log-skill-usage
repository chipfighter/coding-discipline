#!/usr/bin/env bash
# PostToolUse(Skill) hook：记录每次 Skill 激活到 ~/.claude/skill-usage.jsonl（纯本地、不联网）。
# 负载 JSON 从 stdin 进来；**不依赖 jq**，用 grep/sed 尽力抽字段（仅用于本地统计）。
# 路径可用 SKILL_USAGE_LOG 覆盖，便于测试。任何情况下都 exit 0，绝不打断主流程。
LOG="${SKILL_USAGE_LOG:-$HOME/.claude/skill-usage.jsonl}"

payload="$(cat 2>/dev/null || true)"

# 抽 JSON 里第一个 "key":"value"（value 不含未转义引号即可，足够本地统计）。
extract() {
  printf '%s' "$payload" \
    | grep -o "\"$1\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" \
    | head -1 \
    | sed -E "s/.*:[[:space:]]*\"([^\"]*)\"\$/\1/"
}

# 把抽出的值弄成 JSON 安全：Windows 反斜杠 -> 正斜杠（免去转义、更好读、
# 且 skills-count.sh 的子串匹配照样能用），再转义残留的双引号。保证整行永远可被 JSON.parse。
sanitize() {
  local s="$1"
  s="${s//\\//}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

skill="$(sanitize "$(extract skill)")";        [ -n "$skill" ]   || skill="?"
session="$(sanitize "$(extract session_id)")"; [ -n "$session" ] || session="?"
cwd="$(sanitize "$(extract cwd)")";            [ -n "$cwd" ]     || cwd="?"
ts="$(date -u +%FT%TZ 2>/dev/null || echo '?')"

printf '{"ts":"%s","skill":"%s","session":"%s","cwd":"%s"}\n' \
  "$ts" "$skill" "$session" "$cwd" >> "$LOG" 2>/dev/null || true
exit 0
