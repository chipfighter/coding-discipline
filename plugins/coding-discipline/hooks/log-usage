#!/usr/bin/env bash
# Claude Code PostToolUse(Skill) hook: Tier 2 counting records one
# {event:"skill"} entry per invocation.
# The JSON payload arrives on stdin. Extract the skill name with grep/sed
# (no jq), then hand it to the shared writer.
# Always exit 0; usage logging must never interrupt the main workflow.
# Codex loads skills internally through progressive disclosure rather than a
# tool call, so it exposes no per-skill event for this hook.
PATH="/usr/bin:/mingw64/bin:${PATH:-}"
export PATH
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/usage-lib.sh"

payload="$(cat 2>/dev/null || true)"

extract() {
  printf '%s' "$payload" \
    | grep -o "\"$1\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" \
    | head -1 | sed -E "s/.*:[[:space:]]*\"([^\"]*)\"\$/\1/"
}

skill="$(extract skill)"; [ -n "$skill" ] || skill="?"
cwd="$(extract cwd)"

cd_write_record skill "$skill" "$cwd"
exit 0
