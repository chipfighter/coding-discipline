#!/usr/bin/env bash
# Cross-platform SessionStart hook:
# 1. Inject the skill-discipline primer.
# 2. Record one Tier 1 session activation.
# Reads skill-discipline.md beside this file, escapes it as JSON with pure bash
# (no jq), and selects the host-specific output field.
PATH="/usr/bin:/mingw64/bin:${PATH:-}"
export PATH
set -euo pipefail

case "${1:-}" in
  codex|claude-code|cursor|copilot) export CD_PLATFORM="$1" ;;
  "") ;;
  *) printf 'session-start-skills: unsupported platform: %s\n' "$1" >&2; exit 2 ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/usage-lib.sh"

body="$(cat "${SCRIPT_DIR}/skill-discipline.md" 2>/dev/null \
  || echo '(Skill discipline file missing: hooks/skill-discipline.md)')"

# Keep the primer host-neutral; append only the host-specific invocation note.
platform="$(cd_detect_platform)"
case "$platform" in
  claude-code) mech='> On this host, invoke the skill with the **Skill tool**. Reading `SKILL.md` as an ordinary file does not count as invoking it.' ;;
  codex)       mech='> On this host, Codex can load a skill automatically from its description or explicitly through `$skill-name`. Do not load it by printing the file yourself.' ;;
  *)           mech='> Load skills through the skill mechanism of this host. Reading `SKILL.md` as an ordinary file does not count as invoking it.' ;;
esac

# Escape a JSON string with bash parameter expansion only.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"; s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"; s="${s//$'\r'/\\r}"; s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

wrapped="<EXTREMELY_IMPORTANT>
${body}
${mech}
</EXTREMELY_IMPORTANT>"
esc="$(escape_for_json "$wrapped")"

# Tier 1 counting writes to a file and does not affect the injection JSON.
cd_write_record session "" "$PWD"

# Seed an empty project guide at the Git root on first entry. Create only,
# never overwrite, and never interrupt the main workflow. The skeleton stays
# deliberately empty and grows one confirmed line at a time under
# context-hygiene; this hook must not hard-code project facts.
seed_agent_doc() {
  case "${CD_SEED_AGENT_DOC:-1}" in
    0|false|False|FALSE|no|No|NO|off|Off|OFF) return 0 ;;
  esac
  local repo_root target
  repo_root="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null)" || return 0
  local seed="${SCRIPT_DIR}/../templates/agent-doc.seed.md"
  [ -f "$seed" ] || return 0
  case "$platform" in
    codex)       target="${repo_root}/AGENTS.md" ;;
    claude-code) target="${repo_root}/CLAUDE.md" ;;
    *) return 0 ;;
  esac
  [ -e "$target" ] || cp -n "$seed" "$target" 2>/dev/null || true
}
seed_agent_doc || true

# Cursor uses additional_context; Copilot/SDK uses top-level additionalContext;
# Claude Code, Codex, and the default path use
# hookSpecificOutput.additionalContext.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{"additional_context":"%s"}\n' "$esc"
elif [ -n "${COPILOT_CLI:-}" ]; then
  printf '{"additionalContext":"%s"}\n' "$esc"
else
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$esc"
fi

exit 0
